<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Your Profile — StayEase</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet" />
    <style>
        :root {
            --primary-blue: #003580;
            --secondary-blue: #006ce4;
            --accent-yellow: #febb02;
            --light-bg: #f5f5f5;
            --text-main: #1a1a1a;
            --text-muted: #4d4d4d;
            --border-color: #e7e7e7;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f5f5f5;
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ── Header ── */
        .header {
            background-color: var(--primary-blue);
            padding: 16px 20px;
            color: #fff;
        }

        .navbar {
            max-width: 1100px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-size: 24px;
            font-weight: 700;
            text-decoration: none;
            color: #fff;
        }

        /* ── Profile Section ── */
        .profile-container {
            max-width: 1100px;
            margin: 40px auto;
            width: 100%;
            padding: 0 20px;
        }

        .user-card {
            background: #fff;
            padding: 32px;
            border-radius: 8px;
            border: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            gap: 24px;
            margin-bottom: 32px;
        }

        .profile-avatar {
            width: 80px;
            height: 80px;
            background: var(--secondary-blue);
            color: #fff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            font-weight: 700;
        }

        .user-info h1 {
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .user-info p {
            font-size: 14px;
            color: var(--text-muted);
        }

        /* ── Tabs ── */
        .tabs-container {
            background: #fff;
            border-radius: 8px;
            border: 1px solid var(--border-color);
            overflow: hidden;
        }

        .tabs-header {
            display: flex;
            border-bottom: 1px solid var(--border-color);
            background: #fff;
        }

        .tab-btn {
            padding: 16px 24px;
            font-size: 14px;
            font-weight: 600;
            color: var(--text-muted);
            cursor: pointer;
            border: none;
            background: none;
            border-bottom: 3px solid transparent;
            transition: all 0.2s;
        }

        .tab-btn:hover {
            color: var(--secondary-blue);
            background: #f0f7ff;
        }

        .tab-btn.active {
            color: var(--secondary-blue);
            border-bottom-color: var(--secondary-blue);
        }

        .tab-content {
            padding: 32px;
            display: none;
        }

        .tab-content.active {
            display: block;
        }

        /* ── Lists ── */
        .item-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .list-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px;
            border: 1px solid var(--border-color);
            border-radius: 4px;
            transition: all 0.2s;
        }

        .list-item:hover {
            border-color: var(--secondary-blue);
            background: #fcfcfc;
        }

        .item-main h3 {
            font-size: 16px;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .item-main p {
            font-size: 13px;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .item-price {
            font-weight: 700;
            color: var(--text-main);
        }

        .status-confirmed {
            color: #28a745;
        }

        .empty-state {
            text-align: center;
            padding: 48px 0;
        }

        .empty-state i {
            font-size: 48px;
            color: #ddd;
            margin-bottom: 16px;
        }

        .empty-state p {
            font-size: 14px;
            color: var(--text-muted);
        }

        .btn-action {
            display: inline-block;
            margin-top: 16px;
            padding: 10px 20px;
            background: var(--secondary-blue);
            color: #fff;
            text-decoration: none;
            border-radius: 4px;
            font-size: 14px;
            font-weight: 600;
        }

        .btn-action:hover {
            background: #0056b3;
        }

        @media (max-width: 600px) {
            .user-card {
                flex-direction: column;
                text-align: center;
            }

            .tabs-header {
                flex-direction: column;
            }

            .tab-btn {
                width: 100%;
                text-align: left;
            }
        }
    </style>
</head>

<body>
    <header class="header">
        <nav class="navbar">
            <a href="/" class="logo">StayEase.com</a>
        </nav>
    </header>

    <main class="profile-container">
        <section class="user-card">
            <div class="profile-avatar">
                <%= typeof name !=='undefined' ? name.charAt(0).toUpperCase() : 'U' %>
            </div>
            <div class="user-info">
                <h1>
                    <%= user || 'Guest User' %>
                </h1>
                <p>
                    <%= email || 'No email provided' %>
                </p>
            </div>
        </section>

        <section class="tabs-container">
            <div class="tabs-header">
                <button class="tab-btn active" onclick="openTab(event, 'listed')">Listed Properties</button>
                <button class="tab-btn" onclick="openTab(event, 'booked')">Booked Properties</button>
            </div>

            <!-- Listed Properties Tab -->
            <div id="listed" class="tab-content active">
                <% if (typeof listedProperties !=='undefined' && listedProperties.length> 0) { %>
                    <div class="item-list">
                        <% listedProperties.forEach(hotel=> { %>
                            <div class="list-item">
                                <div class="item-main">
                                    <h3>
                                        <%= hotel.hotelName %>
                                    </h3>
                                    <p><i class="material-icons-outlined" style="font-size: 16px;">location_on</i>
                                        <%= hotel.location %>
                                    </p>
                                </div>
                                <div class="item-price">
                                    ₹<%= hotel.price %> / night
                                </div>
                            </div>
                            <% }); %>
                    </div>
                    <% } else { %>
                        <div class="empty-state">
                            <i class="material-icons-outlined">business</i>
                            <p>You haven't listed any properties yet.</p>
                            <a href="/add-property" class="btn-action">List your property</a>
                        </div>
                        <% } %>
            </div>

            <!-- Booked Properties Tab -->
            <div id="booked" class="tab-content">
                <% if (typeof bookedProperties !=='undefined' && bookedProperties.length> 0) { %>
                    <div class="item-list">
                        <% bookedProperties.forEach(booking=> { %>
                            <div class="list-item">
                                <div class="item-main">
                                    <h3>
                                        <%= booking.hotelName || 'Property Booking' %>
                                    </h3>
                                    <p><i class="material-icons-outlined" style="font-size: 16px;">event</i>
                                        <%= new Date(booking.checkin).toLocaleDateString() %> — <%= new
                                                Date(booking.checkout).toLocaleDateString() %>
                                    </p>
                                </div>
                                <div
                                    class="item-price <%= (booking.status || 'Confirmed') === 'Confirmed' ? 'status-confirmed' : '' %>">
                                    <%= booking.status || 'Confirmed' %>
                                </div>
                            </div>
                            <% }); %>
                    </div>
                    <% } else { %>
                        <div class="empty-state">
                            <i class="material-icons-outlined">event_busy</i>
                            <p>No bookings found.</p>
                            <a href="/" class="btn-action">Start searching</a>
                        </div>
                        <% } %>
            </div>
        </section>
    </main>

    <script>
        function openTab(evt, tabName) {
            var i, tabcontent, tablinks;
            tabcontent = document.getElementsByClassName("tab-content");
            for (i = 0; i < tabcontent.length; i++) {
                tabcontent[i].style.display = "none";
                tabcontent[i].classList.remove("active");
            }
            tablinks = document.getElementsByClassName("tab-btn");
            for (i = 0; i < tablinks.length; i++) {
                tablinks[i].classList.remove("active");
            }
            document.getElementById(tabName).style.display = "block";
            document.getElementById(tabName).classList.add("active");
            evt.currentTarget.classList.add("active");
        }
    </script>
</body>

</html>