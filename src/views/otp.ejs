<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify OTP</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', sans-serif;
            background: url('/images/hotel-bg.png') center/cover no-repeat fixed;
            position: relative;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background: inherit;
            filter: blur(10px);
            z-index: -2;
        }

        body::after {
            content: '';
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.55);
            z-index: -1;
        }

        .card {
            background: #fff;
            border-radius: 12px;
            padding: 44px 36px;
            width: 100%;
            max-width: 380px;
            box-shadow: 0 4px 24px rgba(0, 0, 0, 0.12);
        }

        .card h2 {
            color: #1a1a1a;
            font-size: 1.4rem;
            font-weight: 600;
            margin-bottom: 4px;
            text-align: center;
        }

        .card p {
            color: #888;
            font-size: 0.82rem;
            font-weight: 300;
            text-align: center;
            margin-bottom: 28px;
        }

        .form-group {
            margin-bottom: 18px;
        }

        .form-group label {
            display: block;
            color: #555;
            font-size: 0.78rem;
            font-weight: 500;
            margin-bottom: 5px;
            letter-spacing: 0.3px;
        }

        .form-group input {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid #ddd;
            border-radius: 6px;
            background: #fafafa;
            color: #1a1a1a;
            font-size: 0.88rem;
            font-family: inherit;
            outline: none;
            transition: border-color 0.2s;
        }

        .form-group input::placeholder {
            color: #bbb;
        }

        .form-group input:focus {
            border-color: #333;
            background: #fff;
        }

        .btn-submit {
            width: 100%;
            padding: 11px;
            border: none;
            border-radius: 6px;
            background: #1a1a1a;
            color: #fff;
            font-size: 0.88rem;
            font-weight: 500;
            font-family: inherit;
            cursor: pointer;
            margin-top: 6px;
            transition: opacity 0.2s;
            letter-spacing: 0.3px;
        }

        .btn-submit:hover {
            opacity: 0.85;
        }
    </style>
</head>

<body>
    <div class="card">
        <h2>Verify OTP</h2>
        <p>Enter the 4-digit code sent to your email</p>
        <form action="/otp" method="POST">
            <div class="form-group">
                <label for="otp">OTP</label>
                <input type="text" id="otp" name="otp" maxlength="4" placeholder="1234" required />
            </div>
            <button type="submit" class="btn-submit">Submit</button>
        </form>
    </div>
</body>

</html>