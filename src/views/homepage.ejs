<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>StayEase — Find Your Stay</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', sans-serif;
            background: url('/images/hotel-bg.png') center/cover no-repeat fixed;
            position: relative;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background: inherit;
            filter: blur(10px);
            z-index: -2;
        }

        body::after {
            content: '';
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.55);
            z-index: -1;
        }

        h1 {
            color: #fff;
            font-size: 2.2rem;
            font-weight: 600;
            letter-spacing: -0.5px;
            margin-bottom: 28px;
        }

        /* ── Search Bar ── */
        .search-bar {
            display: flex;
            align-items: stretch;
            background: #fff;
            border-radius: 8px;
            border: 3px solid #f5a623;
            overflow: hidden;
            width: 100%;
            max-width: 960px;
            box-shadow: 0 4px 24px rgba(0, 0, 0, 0.18);
        }

        .search-field {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0 18px;
            flex: 1;
            border-right: 1px solid #e0e0e0;
            min-height: 52px;
        }

        .search-field:last-of-type {
            border-right: none;
        }

        .search-field .material-icons-outlined {
            font-size: 20px;
            color: #333;
            flex-shrink: 0;
        }

        .search-field input,
        .search-field select {
            border: none;
            outline: none;
            font-family: inherit;
            font-size: 0.85rem;
            color: #1a1a1a;
            background: transparent;
            width: 100%;
        }

        .search-field input::placeholder {
            color: #888;
        }

        .search-field select {
            cursor: pointer;
            -webkit-appearance: none;
            appearance: none;
            color: #555;
        }

        /* Date pair */
        .date-pair {
            display: flex;
            align-items: center;
            gap: 0;
            width: 100%;
        }

        .date-pair input {
            width: 50%;
            text-align: center;
        }

        .date-pair span {
            color: #bbb;
            font-size: 0.85rem;
            padding: 0 4px;
        }

        /* Rooms stepper */
        .room-stepper {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .room-stepper .stepper-btn {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            border: 1.5px solid #006ce4;
            background: transparent;
            color: #006ce4;
            font-size: 1.1rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.15s;
            flex-shrink: 0;
            line-height: 1;
        }

        .room-stepper .stepper-btn:hover {
            background: #006ce4;
            color: #fff;
        }

        .room-stepper .stepper-value {
            font-size: 0.88rem;
            font-weight: 500;
            color: #1a1a1a;
            min-width: 14px;
            text-align: center;
        }

        .room-stepper .stepper-label {
            font-size: 0.82rem;
            color: #555;
            white-space: nowrap;
        }

        /* Search button */
        .btn-search {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 28px;
            background: #006ce4;
            color: #fff;
            border: none;
            font-family: inherit;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            letter-spacing: 0.3px;
            white-space: nowrap;
            transition: background 0.2s;
        }

        .btn-search:hover {
            background: #0057b8;
        }

        /* Mobile */
        @media (max-width: 768px) {
            .search-bar {
                flex-direction: column;
                max-width: 400px;
                border-radius: 10px;
            }

            .search-field {
                border-right: none;
                border-bottom: 1px solid #e0e0e0;
            }

            .search-field:last-of-type {
                border-bottom: none;
            }

            .btn-search {
                padding: 14px;
                border-radius: 0 0 7px 7px;
            }
        }
    </style>
</head>

<body>
    <h1>StayEase</h1>

    <form class="search-bar" action="/search" method="POST">
        <!-- Destination -->
        <div class="search-field">
            <span class="material-icons-outlined">hotel</span>
            <input type="text" name="destination" placeholder="Where are you going?" required />
        </div>

        <!-- Dates -->
        <div class="search-field">
            <span class="material-icons-outlined">calendar_today</span>
            <div class="date-pair">
                <input type="date" name="checkin" required />
                <span>—</span>
                <input type="date" name="checkout" required />
            </div>
        </div>

        <!-- Adults -->
        <div class="search-field">
            <span class="material-icons-outlined">person_outline</span>
            <div class="room-stepper">
                <button type="button" class="stepper-btn" id="adults-minus">−</button>
                <span class="stepper-value" id="adults-value">2</span>
                <button type="button" class="stepper-btn" id="adults-plus">+</button>
                <span class="stepper-label">Adults</span>
            </div>
            <input type="hidden" name="adults" id="adults-input" value="2" />
        </div>

        <!-- Children -->
        <!-- <div class="search-field">
            <span class="material-icons-outlined">child_care</span>
            <div class="room-stepper">
                <button type="button" class="stepper-btn" id="children-minus">−</button>
                <span class="stepper-value" id="children-value">0</span>
                <button type="button" class="stepper-btn" id="children-plus">+</button>
                <span class="stepper-label">Children</span>
            </div>
            <input type="hidden" name="children" id="children-input" value="0" />
        </div> -->

        <!-- Rooms -->
        <div class="search-field">
            <span class="material-icons-outlined">meeting_room</span>
            <div class="room-stepper">
                <button type="button" class="stepper-btn" id="rooms-minus">−</button>
                <span class="stepper-value" id="rooms-value">1</span>
                <button type="button" class="stepper-btn" id="rooms-plus">+</button>
                <span class="stepper-label">Rooms</span>
            </div>
            <input type="hidden" name="rooms" id="rooms-input" value="1" />
        </div>

        <!-- Search button -->
        <button type="submit" class="btn-search">Search</button>
    </form>
    <script>
        function setupStepper(id, min, max) {
            const value = document.getElementById(id + '-value');
            const input = document.getElementById(id + '-input');
            document.getElementById(id + '-minus').addEventListener('click', () => {
                let v = Math.max(min, parseInt(input.value) - 1);
                input.value = v;
                value.textContent = v;
            });
            document.getElementById(id + '-plus').addEventListener('click', () => {
                let v = Math.min(max, parseInt(input.value) + 1);
                input.value = v;
                value.textContent = v;
            });
        }

        setupStepper('adults', 1, 10);
        setupStepper('children', 0, 10);
        setupStepper('rooms', 1, 10);
    </script>
</body>

</html>