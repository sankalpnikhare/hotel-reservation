<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= hotel.hotelName %> — StayEase
    </title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet" />
    <style>
        :root {
            --primary-blue: #003580;
            --secondary-blue: #006ce4;
            --accent-yellow: #febb02;
            --light-bg: #f5f5f5;
            --text-main: #1a1a1a;
            --text-muted: #4d4d4d;
            --border-color: #e7e7e7;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #fff;
            color: var(--text-main);
            line-height: 1.5;
        }

        /* ── Header ── */
        .header {
            background-color: var(--primary-blue);
            padding: 16px 20px;
            color: #fff;
        }

        .navbar {
            max-width: 1100px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-size: 24px;
            font-weight: 700;
            text-decoration: none;
            color: #fff;
        }

        .back-btn {
            color: #fff;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        /* ── Main Content ── */
        .container {
            max-width: 1100px;
            margin: 30px auto;
            padding: 0 20px;
        }

        .hotel-header {
            margin-bottom: 24px;
        }

        .hotel-name {
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .hotel-location {
            font-size: 14px;
            color: var(--secondary-blue);
            text-decoration: underline;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        /* ── Photo Gallery ── */
        .gallery {
            display: grid;
            grid-template-columns: 2fr 1fr;
            grid-template-rows: 200px 200px;
            gap: 8px;
            margin-bottom: 30px;
            border-radius: 8px;
            overflow: hidden;
        }

        .gallery-main {
            grid-row: span 2;
        }

        .gallery img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            cursor: pointer;
            transition: opacity 0.2s;
        }

        .gallery img:hover {
            opacity: 0.9;
        }

        /* ── Detail Grid ── */
        .detail-grid {
            display: grid;
            grid-template-columns: 1fr 350px;
            gap: 30px;
        }

        .description {
            font-size: 16px;
            color: var(--text-main);
            margin-bottom: 32px;
        }

        .amenities-section h3 {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 16px;
        }

        .amenities-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 12px;
        }

        .amenity-item {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
        }

        .amenity-item i {
            color: #262626;
            font-size: 20px;
        }

        /* ── Booking Sidebar ── */
        .booking-sidebar {
            background: #ebf3ff;
            padding: 24px;
            border-radius: 8px;
            align-self: start;
        }

        .sidebar-title {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 16px;
        }

        .price-section {
            margin-bottom: 20px;
        }

        .price-val {
            font-size: 28px;
            font-weight: 700;
        }

        .price-sub {
            font-size: 12px;
            color: var(--text-muted);
        }

        .btn-reserve {
            display: block;
            width: 100%;
            background: var(--secondary-blue);
            color: #fff;
            text-align: center;
            padding: 12px;
            border-radius: 4px;
            font-size: 16px;
            font-weight: 600;
            text-decoration: none;
            border: none;
            cursor: pointer;
            transition: background 0.2s;
        }

        .btn-reserve:hover {
            background: #0056b3;
        }

        /* Mobile */
        @media (max-width: 768px) {
            .detail-grid {
                grid-template-columns: 1fr;
            }

            .gallery {
                grid-template-columns: 1fr;
                grid-template-rows: 250px;
            }

            .gallery-item {
                display: none;
            }
        }
    </style>
</head>

<body>
    <header class="header">
        <nav class="navbar">
            <a href="/" class="logo">StayEase.com</a>
            <a href="javascript:history.back()" class="back-btn">
                <span class="material-icons-outlined">arrow_back</span>
                Back to results
            </a>
        </nav>
    </header>

    <main class="container">
        <div class="hotel-header">
            <h1 class="hotel-name">
                <%= hotel.hotelName %>
            </h1>
            <div class="hotel-location">
                <span class="material-icons-outlined">location_on</span>
                <span>
                    <%= hotel.location %>
                </span>
            </div>
        </div>

        <div class="gallery">
            <div class="gallery-main">
                <img src="<%= (hotel.photos && hotel.photos.length > 0) ? hotel.photos[0] : 'https://via.placeholder.com/800x600?text=Premium+Stay' %>"
                    alt="Main Photo">
            </div>
            <% for(let i=1; i<3; i++) { %>
                <div class="gallery-item">
                    <img src="<%= (hotel.photos && hotel.photos.length > i) ? hotel.photos[i] : 'https://via.placeholder.com/400x300?text=StayEase+View' %>"
                        alt="Photo <%= i+1 %>">
                </div>
                <% } %>
        </div>

        <div class="detail-grid">
            <div class="detail-main">
                <div class="description">
                    <p>
                        <%= hotel.description || 'Welcome to ' + hotel.hotelName
                            + '. Experience unparalleled comfort and luxury in the heart of ' +
                            hotel.location.split(',')[0]
                            + '. Our hotel offers premium amenities, stunning views, and world-class service to ensure your stay is nothing short of extraordinary.'
                            %>
                    </p>
                </div>

                <div class="amenities-section">
                    <h3>Most popular facilities</h3>
                    <div class="amenities-grid">
                        <div class="amenity-item"><i class="material-icons-outlined">wifi</i><span>Free WiFi</span>
                        </div>
                        <div class="amenity-item"><i class="material-icons-outlined">pool</i><span>Swimming pool</span>
                        </div>
                        <div class="amenity-item"><i class="material-icons-outlined">fitness_center</i><span>Fitness
                                center</span></div>
                        <div class="amenity-item"><i
                                class="material-icons-outlined">restaurant</i><span>Restaurant</span></div>
                        <div class="amenity-item"><i class="material-icons-outlined">ac_unit</i><span>Air
                                conditioning</span></div>
                        <div class="amenity-item"><i class="material-icons-outlined">room_service</i><span>Room
                                service</span></div>
                    </div>
                </div>
            </div>

            <aside class="booking-sidebar">
                <h3 class="sidebar-title">Property highlights</h3>
                <div class="price-section">
                    <p class="price-sub">Price starting from</p>
                    <p class="price-val">₹<%= hotel.price %>
                    </p>
                </div>

                <form action='/reserve' method="post">
                    <% if (typeof session !=='undefined' ) { %>
                        <input type="hidden" name="rooms" value="<%= session.rooms %>">
                        <input type="hidden" name="adults" value="<%= session.adults %>">
                        <input type="hidden" name="checkin" value="<%= session.checkin %>">
                        <input type="hidden" name="checkout" value="<%= session.checkout %>">
                        <input type="hidden" name="name" value="<%= session.name %>">
                        <input type="hidden" name="email" value="<%= session.email %>">
                        <input type="hidden" name="hotelid" value="<%= hotel._id %>">
                        <% } %>
                            <button type="submit" class="btn-reserve">Reserve Now</button>
                </form>

                <p style="font-size: 12px; margin-top: 12px; color: var(--text-muted);">
                    <i class="material-icons-outlined" style="font-size: 14px; vertical-align: middle;">bolt</i>
                    Confirmation is immediate
                </p>
            </aside>
        </div>
    </main>
</body>

</html>