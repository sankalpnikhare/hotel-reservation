<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Hotel — StayEase</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet" />
    <style>
        :root {
            --primary-blue: #003580;
            --secondary-blue: #006ce4;
            --accent-yellow: #febb02;
            --light-bg: #f5f5f5;
            --text-main: #1a1a1a;
            --text-muted: #4d4d4d;
            --border-color: #ced4da;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #fff;
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ── Header ── */
        .header {
            background-color: var(--primary-blue);
            padding: 16px 20px;
            color: #fff;
        }

        .navbar {
            max-width: 1100px;
            margin: 0 auto;
            display: flex;
            justify-content: flex-start;
            align-items: center;
        }

        .logo {
            font-size: 24px;
            font-weight: 700;
            text-decoration: none;
            color: #fff;
        }

        /* ── Main Content ── */
        .main-container {
            flex: 1;
            padding: 40px 20px;
            background-color: #fff;
        }

        .form-card {
            max-width: 800px;
            margin: 0 auto;
            background: #fff;
            padding: 32px;
            border: 1px solid #e7e7e7;
            border-radius: 8px;
        }

        .form-card h1 {
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .form-card p.subtitle {
            font-size: 14px;
            color: var(--text-muted);
            margin-bottom: 32px;
        }

        .form-group {
            margin-bottom: 24px;
        }

        .label-wrapper {
            display: block;
            margin-bottom: 8px;
            font-size: 14px;
            font-weight: 600;
        }

        .input-field {
            width: 100%;
            padding: 12px;
            border: 1px solid var(--border-color);
            border-radius: 4px;
            font-family: inherit;
            font-size: 14px;
            outline: none;
            transition: border-color 0.2s;
        }

        .input-field:focus {
            border-color: var(--secondary-blue);
            box-shadow: 0 0 0 1px var(--secondary-blue);
        }

        /* Stepper Styling */
        .stepper {
            display: flex;
            align-items: center;
            gap: 12px;
            width: max-content;
        }

        .stepper-btn {
            width: 32px;
            height: 32px;
            border: 1px solid var(--secondary-blue);
            background: transparent;
            color: var(--secondary-blue);
            border-radius: 4px;
            font-size: 20px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .stepper-btn:hover {
            background: #f0f7ff;
        }

        .stepper-value {
            font-size: 16px;
            font-weight: 600;
            min-width: 20px;
            text-align: center;
        }

        /* Photo Upload Styling */
        .photo-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 12px;
        }

        .photo-slot {
            aspect-ratio: 1/1;
            border: 1px dashed var(--border-color);
            border-radius: 4px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            background: #f9f9f9;
        }

        .photo-slot:hover {
            background: #f1f1f1;
            border-color: var(--text-muted);
        }

        .photo-slot i {
            font-size: 24px;
            color: var(--text-muted);
            margin-bottom: 4px;
        }

        .photo-slot span {
            font-size: 10px;
            color: var(--text-muted);
        }

        .photo-slot img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            position: absolute;
            inset: 0;
            z-index: 1;
        }

        .btn-submit {
            width: 100%;
            padding: 14px;
            background-color: var(--secondary-blue);
            color: #fff;
            border: none;
            border-radius: 4px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s;
            margin-top: 32px;
        }

        .btn-submit:hover {
            background-color: #0056b3;
        }

        @media (max-width: 600px) {
            .photo-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
    </style>
</head>

<body>
    <header class="header">
        <nav class="navbar">
            <a href="/" class="logo">StayEase.com</a>
        </nav>
    </header>

    <main class="main-container">
        <div class="form-card">
            <h1>Hotel Details</h1>
            <p class="subtitle">Please enter your hotel information below</p>

            <form action="/add-hotel" method="POST" enctype="multipart/form-data">
                <div class="form-group">
                    <label class="label-wrapper" for="hotelName">Hotel Name</label>
                    <input type="text" id="hotelName" name="hotelName" class="input-field"
                        placeholder="e.g. Grand Hyatt" required />
                </div>

                <div class="form-group">
                    <label class="label-wrapper" for="location">Hotel Location</label>
                    <select id="location" name="location" class="input-field" required>
                        <option value="" disabled selected>Select Location</option>
                        <option value="Nagpur, India">Nagpur, India</option>
                        <option value="Gondia, India">Gondia, India</option>
                        <option value="Wardha, India">Wardha, India</option>
                        <option value="Mumbai, India">Mumbai, India</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="label-wrapper">Total Rooms</label>
                    <div class="stepper">
                        <button type="button" class="stepper-btn" id="rooms-minus">−</button>
                        <span class="stepper-value" id="rooms-value">1</span>
                        <button type="button" class="stepper-btn" id="rooms-plus">+</button>
                    </div>
                    <input type="hidden" name="totalRooms" id="rooms-input" value="1" />
                </div>

                <div class="form-group">
                    <label class="label-wrapper" for="price">Price per Night (₹)</label>
                    <input type="number" id="price" name="price" class="input-field" placeholder="e.g. 5000" min="0"
                        required />
                </div>

                <div class="form-group">
                    <label class="label-wrapper">Hotel Photos (4 required)</label>
                    <div class="photo-grid">
                        <% for(let i=1; i<=4; i++) { %>
                            <div class="photo-slot" onclick="document.getElementById('photo<%= i %>').click()"
                                id="slot<%= i %>">
                                <i class="material-icons-outlined">add_a_photo</i>
                                <span>Upload</span>
                                <input type="file" id="photo<%= i %>" name="hotelPhotos" accept="image/*"
                                    onchange="previewImage(this, 'slot<%= i %>')" style="display: none;" required />
                            </div>
                            <% } %>
                    </div>
                </div>

                <button type="submit" class="btn-submit">Add Hotel</button>
            </form>
        </div>
    </main>

    <script>
        const params = new URLSearchParams(window.location.search);
        if (params.get("success")) {
            window.history.replaceState({}, document.title, "/hotel");
            const popup = document.createElement("div");
            popup.innerText = "Hotel added successfully";
            Object.assign(popup.style, {
                position: "fixed", top: "20px", right: "20px", background: "#008009", color: "white",
                padding: "15px 20px", borderRadius: "4px", zIndex: "1000", fontSize: "14px", fontWeight: "600"
            });
            document.body.appendChild(popup);
            setTimeout(() => { popup.style.opacity = "0"; }, 3000);
            setTimeout(() => { popup.remove(); window.location.href = "/homepage"; }, 3500);
        }

        const roomsValue = document.getElementById('rooms-value');
        const roomsInput = document.getElementById('rooms-input');
        function updateRooms(delta) {
            let val = parseInt(roomsInput.value) + delta;
            val = Math.max(1, Math.min(500, val));
            roomsInput.value = val;
            roomsValue.textContent = val;
        }
        document.getElementById('rooms-minus').addEventListener('click', () => updateRooms(-1));
        document.getElementById('rooms-plus').addEventListener('click', () => updateRooms(1));

        function previewImage(input, slotId) {
            const slot = document.getElementById(slotId);
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    const existingImg = slot.querySelector('img');
                    if (existingImg) existingImg.remove();
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    slot.appendChild(img);
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
</body>

</html>