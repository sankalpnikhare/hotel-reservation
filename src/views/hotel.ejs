<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Hotel — StayEase</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', sans-serif;
            background: url('/images/hotel-bg.png') center/cover no-repeat fixed;
            position: relative;
            padding: 20px;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background: inherit;
            filter: blur(10px);
            z-index: -2;
        }

        body::after {
            content: '';
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.55);
            z-index: -1;
        }

        .form-container {
            background: #fff;
            padding: 30px;
            border-radius: 12px;
            width: 100%;
            max-width: 1100px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
        }

        h1 {
            color: #1a1a1a;
            font-size: 1.8rem;
            font-weight: 600;
            margin-bottom: 8px;
            text-align: center;
        }

        p.subtitle {
            color: #666;
            font-size: 0.9rem;
            margin-bottom: 32px;
            text-align: center;
        }

        .form-group {
            margin-bottom: 16px;
        }

        .label-wrapper {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 8px;
            color: #333;
            font-weight: 500;
            font-size: 0.9rem;
        }

        .label-wrapper .material-icons-outlined {
            font-size: 18px;
            color: #006ce4;
        }

        .input-field {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid #ddd;
            border-radius: 6px;
            font-family: inherit;
            font-size: 0.95rem;
            outline: none;
            transition: border-color 0.2s;
        }

        .input-field:focus {
            border-color: #006ce4;
        }

        /* Stepper Styling */
        .stepper {
            display: flex;
            align-items: center;
            gap: 8px;
            background: #f9f9f9;
            padding: 8px 16px;
            border-radius: 6px;
            border: 1px solid #ddd;
            width: max-content;
        }

        .stepper-btn {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            border: 1.5px solid #006ce4;
            background: transparent;
            color: #006ce4;
            font-size: 1.2rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.15s;
            line-height: 1;
        }

        .stepper-btn:hover {
            background: #006ce4;
            color: #fff;
        }

        .stepper-value {
            font-size: 1rem;
            font-weight: 600;
            color: #1a1a1a;
            min-width: 20px;
            text-align: center;
        }

        .btn-submit {
            width: 100%;
            padding: 14px;
            background: #006ce4;
            color: #fff;
            border: none;
            border-radius: 6px;
            font-family: inherit;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s;
            margin-top: 8px;
        }

        .btn-submit:hover {
            background: #0057b8;
        }

        /* Photo Upload Styling */
        .photos-container {
            margin-bottom: 24px;
        }

        .photo-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
            margin-top: 12px;
        }

        .photo-slot {
            aspect-ratio: 1 / 1;
            border: 2px dashed #ddd;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            background: #fcfcfc;
            transition: all 0.2s;
        }

        .photo-slot:hover {
            border-color: #006ce4;
            background: #f0f7ff;
        }

        .photo-slot .material-icons-outlined {
            font-size: 32px;
            color: #aaa;
        }

        .photo-slot img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            position: absolute;
            top: 0;
            left: 0;
            z-index: 1;
        }

        .photo-slot input[type="file"] {
            display: none;
        }

        .photo-slot.has-image {
            border: 1.5px solid #006ce4;
        }

        .photo-slot.has-image .material-icons-outlined {
            display: none;
        }
    </style>
</head>

<body>
    <div class="form-container">
        <h1>Hotel Details</h1>
        <p class="subtitle">Please enter your hotel information below</p>

        <form action="/add-hotel" method="POST" enctype="multipart/form-data">
            <!-- Hotel Name -->
            <div class="form-group">
                <div class="label-wrapper">
                    <span class="material-icons-outlined">hotel</span>
                    <label for="hotelName">Hotel Name</label>
                </div>
                <input type="text" id="hotelName" name="hotelName" class="input-field" placeholder="e.g. Grand Hyatt"
                    required />
            </div>

            <!-- Hotel Location -->
            <div class="form-group">
                <div class="label-wrapper">
                    <span class="material-icons-outlined">location_on</span>
                    <label for="location">Hotel Location</label>
                </div>
                <select id="location" name="location" class="input-field" required>
                    <option value="" disabled selected>Select Location</option>
                    <option value="Nagpur, India">Nagpur, India</option>
                    <option value="Gondia, India">Gondia, India</option>
                    <option value="Wardha, India">Wardha, India</option>
                    <option value="Mumbai, India">Mumbai, India</option>
                </select>
            </div>

            <!-- Total Rooms -->
            <div class="form-group">
                <div class="label-wrapper">
                    <span class="material-icons-outlined">meeting_room</span>
                    <label>Total Rooms</label>
                </div>
                <div class="stepper">
                    <button type="button" class="stepper-btn" id="rooms-minus">−</button>
                    <span class="stepper-value" id="rooms-value">1</span>
                    <button type="button" class="stepper-btn" id="rooms-plus">+</button>
                </div>
                <input type="hidden" name="totalRooms" id="rooms-input" value="1" />
            </div>

            <!-- Price per Night -->
            <div class="form-group">
                <div class="label-wrapper">
                    <span class="material-icons-outlined">payments</span>
                    <label for="price">Price per Night (₹)</label>
                </div>
                <input type="number" id="price" name="price" class="input-field" placeholder="e.g. 5000" min="0"
                    required />
            </div>

            <!-- Hotel Photos -->
            <div class="photos-container">
                <div class="label-wrapper">
                    <span class="material-icons-outlined">photo_library</span>
                    <label>Hotel Photos (4 required)</label>
                </div>
                <div class="photo-grid">
                    <div class="photo-slot" onclick="document.getElementById('photo1').click()" id="slot1">
                        <span class="material-icons-outlined">add_a_photo</span>
                        <input type="file" id="photo1" name="hotelPhotos" accept="image/*"
                            onchange="previewImage(this, 'slot1')" required />
                    </div>
                    <div class="photo-slot" onclick="document.getElementById('photo2').click()" id="slot2">
                        <span class="material-icons-outlined">add_a_photo</span>
                        <input type="file" id="photo2" name="hotelPhotos" accept="image/*"
                            onchange="previewImage(this, 'slot2')" required />
                    </div>
                    <div class="photo-slot" onclick="document.getElementById('photo3').click()" id="slot3">
                        <span class="material-icons-outlined">add_a_photo</span>
                        <input type="file" id="photo3" name="hotelPhotos" accept="image/*"
                            onchange="previewImage(this, 'slot3')" required />
                    </div>
                    <div class="photo-slot" onclick="document.getElementById('photo4').click()" id="slot4">
                        <span class="material-icons-outlined">add_a_photo</span>
                        <input type="file" id="photo4" name="hotelPhotos" accept="image/*"
                            onchange="previewImage(this, 'slot4')" required />
                    </div>
                </div>
            </div>

            <button type="submit" class="btn-submit">Add Hotel</button>
        </form>
    </div>

    <script>
        const params = new URLSearchParams(window.location.search);

        if (params.get("success")) {

            // remove query param (important)
            window.history.replaceState({}, document.title, "/hotel");

            const popup = document.createElement("div");
            popup.innerText = "Hotel added successfully";

            popup.style.position = "fixed";
            popup.style.top = "20px";
            popup.style.right = "20px";
            popup.style.background = "green";
            popup.style.color = "white";
            popup.style.padding = "15px 20px";
            popup.style.borderRadius = "6px";
            popup.style.zIndex = "1000";
            popup.style.opacity = "1";
            popup.style.transition = "opacity 0.5s ease";

            document.body.appendChild(popup);

            setTimeout(() => {
                popup.style.opacity = "0"; // fade out
            }, 5000);

            setTimeout(() => {
                popup.remove();
                window.location.href = "/homepage";
            }, 6000);
        }
        const roomsValue = document.getElementById('rooms-value');
        const roomsInput = document.getElementById('rooms-input');

        function updateRooms(delta) {
            let val = parseInt(roomsInput.value) + delta;
            val = Math.max(1, Math.min(500, val)); // Max 500 rooms for example
            roomsInput.value = val;
            roomsValue.textContent = val;
        }

        document.getElementById('rooms-minus').addEventListener('click', () => updateRooms(-1));
        document.getElementById('rooms-plus').addEventListener('click', () => updateRooms(1));

        function previewImage(input, slotId) {
            const slot = document.getElementById(slotId);
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    // Remove existing image if any
                    const existingImg = slot.querySelector('img');
                    if (existingImg) existingImg.remove();

                    const img = document.createElement('img');
                    img.src = e.target.result;
                    slot.appendChild(img);
                    slot.classList.add('has-image');
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
</body>

</html>