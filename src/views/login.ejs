<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — StayEase</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
        rel="stylesheet" />
    <style>
        :root {
            --primary-blue: #003580;
            --secondary-blue: #006ce4;
            --accent-yellow: #febb02;
            --light-bg: #f5f5f5;
            --text-main: #1a1a1a;
            --text-muted: #4d4d4d;
            --border-color: #ced4da;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #fff;
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ── Header ── */
        .header {
            background-color: var(--primary-blue);
            padding: 16px 20px;
            color: #fff;
        }

        .navbar {
            max-width: 1100px;
            margin: 0 auto;
            display: flex;
            justify-content: flex-start;
            align-items: center;
        }

        .logo {
            font-size: 24px;
            font-weight: 700;
            text-decoration: none;
            color: #fff;
        }

        /* ── Main Content ── */
        .main-container {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
            background-color: #fff;
        }

        .card {
            width: 100%;
            max-width: 400px;
            padding: 24px;
        }

        .card h2 {
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 24px;
            color: var(--text-main);
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-size: 14px;
            font-weight: 600;
            color: var(--text-main);
        }

        .form-group input {
            width: 100%;
            padding: 12px;
            border: 1px solid var(--border-color);
            border-radius: 4px;
            font-family: inherit;
            font-size: 14px;
            outline: none;
            transition: border-color 0.2s;
        }

        .form-group input:focus {
            border-color: var(--secondary-blue);
            box-shadow: 0 0 0 1px var(--secondary-blue);
        }

        .btn-submit {
            width: 100%;
            padding: 14px;
            background-color: var(--secondary-blue);
            color: #fff;
            border: none;
            border-radius: 4px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s;
            margin-bottom: 20px;
        }

        .btn-submit:hover {
            background-color: #0056b3;
        }

        .footer-link {
            text-align: center;
            font-size: 14px;
            color: var(--text-muted);
        }

        .footer-link a {
            color: var(--secondary-blue);
            text-decoration: none;
            font-weight: 600;
        }

        .footer-link a:hover {
            text-decoration: underline;
        }

        /* Mobile */
        @media (max-width: 480px) {
            .card {
                padding: 16px;
            }
        }
    </style>
</head>

<body>
    <header class="header">
        <nav class="navbar">
            <a href="/" class="logo">StayEase.com</a>
        </nav>
    </header>

    <main class="main-container">
        <section class="card">
            <h2>Welcome Back</h2>
            <form action="/login" method="POST">
                <div class="form-group">
                    <label for="email">Email address</label>
                    <input type="email" id="email" name="email" placeholder="Enter your email" required />
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" placeholder="Enter your password" required />
                </div>
                <button type="submit" class="btn-submit">Login</button>
            </form>
            <p class="footer-link">
                Don't have an account? <a href="/register">Create one</a>
            </p>
        </section>
    </main>
</body>

</html>