<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hotels — StayEase</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet" />

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            min-height: 100vh;
            font-family: 'Inter', sans-serif;
            background: url('/images/hotel-bg.png') center/cover no-repeat fixed;
            position: relative;
            padding: 40px 20px;
            color: #333;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background: inherit;
            filter: blur(10px);
            z-index: -2;
        }

        body::after {
            content: '';
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.45);
            z-index: -1;
        }

        header {
            width: 100%;
            max-width: 1200px;
            margin: 0 auto 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: #fff;
        }

        header h1 {
            font-size: 1.8rem;
            font-weight: 600;
        }

        .back-link {
            color: #fff;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .hotel-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 24px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .hotel-card {
            background: #fff;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
            transition: 0.2s;
            display: block;
            text-decoration: none;
            color: inherit;
        }

        .hotel-card:hover {
            transform: translateY(-5px);
        }

        .hotel-image {
            width: 100%;
            height: 200px;
            object-fit: cover;
            background: #eee;
        }

        .hotel-info {
            padding: 18px;
        }

        .hotel-name {
            font-size: 1.2rem;
            font-weight: 600;
            margin-bottom: 6px;
        }

        .hotel-location {
            display: flex;
            align-items: center;
            gap: 4px;
            font-size: 0.85rem;
            color: #666;
            margin-bottom: 14px;
        }

        .hotel-price {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .price-value {
            font-weight: 600;
            color: #006ce4;
        }

        .btn-book {
            padding: 6px 12px;
            background: #006ce4;
            color: #fff;
            border: none;
            border-radius: 6px;
            font-size: 0.85rem;
            cursor: pointer;
        }

        .no-hotels {
            grid-column: 1 / -1;
            text-align: center;
            padding: 50px;
            background: rgba(255,255,255,0.9);
            border-radius: 10px;
        }
    </style>
</head>

<body>

<header>
    <h1>Hotels in <%= location %></h1>
    <a href="/homepage" class="back-link">
        <span class="material-icons-outlined">arrow_back</span>
        Back
    </a>
</header>

<div class="hotel-grid">

    <% if (hotels && hotels.length > 0) { %>

        <% hotels.forEach(hotel => { %>

            <!-- clickable card -->
            <a href="/hotel/<%= hotel._id %>" class="hotel-card">

                <img 
                    src="<%= (hotel.photos && hotel.photos.length > 0) ? hotel.photos[0] : 'https://via.placeholder.com/400x250?text=No+Image' %>" 
                    class="hotel-image"
                >

                <div class="hotel-info">

                    <div class="hotel-name">
                        <%= hotel.hotelName %>
                    </div>

                    <div class="hotel-location">
                        <span class="material-icons-outlined">location_on</span>
                        <%= hotel.location %>
                    </div>

                    <div class="hotel-price">
                        <span class="price-value">₹<%= hotel.price %> / night</span>
                        <button class="btn-book">View</button>
                    </div>

                </div>

            </a>

        <% }) %>

    <% } else { %>

        <div class="no-hotels">
            <h2>No hotels found 😕</h2>
            <p>Try a different location</p>
        </div>

    <% } %>

</div>

</body>
</html>